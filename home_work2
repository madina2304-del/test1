import tkinter as tk 
count = 0 
def create_window():
    windov = tk.Tk()
    windov.title("Счётчик кликов")
    windov.geometry("300x200")
    

text = tk.Label(windov, text="Нажато: 0 раз", font=("Arial", 16))
text.hello.pack(pady=20)

def on_button_click():
    nonlocal count
    count += 1 

    text.hello.config(text=f"Нажато: {count} раз")

 button = tk.Button(window, text="Нажми меня!", command=on_button_click)
    button.pack(pady=10)

    window.mainloop()

create_window()  


